# Copy to `.env` ON THE SERVER ONLY and fill in real values:
#
#   cp .env.prod.example .env && chmod 600 .env
#
# docker compose reads `.env` from the project directory automatically. `.env` is
# gitignored -- keep it that way; this example file is the only one that is committed.

# Postgres superuser password. Generate, don't invent:
#   openssl rand -base64 24
# Used by both the postgres container and the backend's DB_PASSWORD.
POSTGRES_PASSWORD=

# The public hostname. Caddy provisions a Let's Encrypt certificate for exactly this
# name, so it must already resolve to this server before the stack comes up.
SITE_ADDRESS=ambert.io.vn
